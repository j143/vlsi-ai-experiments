datasets/*.npy
# Keep README in datasets/
!datasets/README.md
# Keep the committed reference dataset (analytical, < 1 MB) for pipeline bootstrapping
!datasets/bandgap_sweep_real_sky130.csv

# Results (generated — do not commit large outputs)
results/*.json
results/*.png
results/*.pdf
results/*.html
# Keep README in results/
!results/README.md

# Model checkpoints (can be large)
ml/checkpoints/
layout/data/*.npy

